# =============================================================================
# CRM Beza, Miranda e Bonetti — Variáveis de ambiente
# Copie para .env e preencha os valores marcados com <CHANGE_ME>
# =============================================================================

# ── Banco de dados ────────────────────────────────────────────────────────────
POSTGRES_DB=crm_beza
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=<CHANGE_ME>          # openssl rand -base64 32

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=<CHANGE_ME>             # openssl rand -base64 32

# ── MinIO (armazenamento de arquivos) ─────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=<CHANGE_ME>        # openssl rand -base64 32

# ── JWT ───────────────────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
SECRET_KEY=<CHANGE_ME>
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Ambiente ──────────────────────────────────────────────────────────────────
ENVIRONMENT=production

# ── Performance (produção) ────────────────────────────────────────────────────
BACKEND_WORKERS=4           # uvicorn workers (recomendado: 2 × núcleos + 1)
CELERY_CONCURRENCY=4        # workers Celery

# ── Primeiro admin (criado automaticamente no startup) ───────────────────────
# IMPORTANTE: troque a senha imediatamente após o primeiro login
FIRST_ADMIN_EMAIL=admin@bezamiranda.com.br
FIRST_ADMIN_PASSWORD=<CHANGE_ME>       # mínimo 8 caracteres, use maiúsculas/números/símbolos
FIRST_ADMIN_NAME=Administrador

# ── Domínio e SSL (Let's Encrypt) ─────────────────────────────────────────────
DOMAIN=crm.bezamiranda.com.br          # domínio principal — sem https://
CERTBOT_EMAIL=ti@bezamiranda.com.br    # e-mail para notificações de expiração

# ── Google Calendar OAuth2 ────────────────────────────────────────────────────
# Crie credenciais em: https://console.cloud.google.com → APIs → Calendar API
# URI autorizado de redirecionamento: https://<DOMAIN>/api/v1/integrations/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://crm.bezamiranda.com.br/api/v1/integrations/google/callback

# ── WhatsApp — Z-API (opção 1) ────────────────────────────────────────────────
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# ── WhatsApp — Evolution API (opção 2) ───────────────────────────────────────
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# ── SMTP (e-mail) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com               # ou smtp.office365.com, etc.
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@bezamiranda.com.br
SMTP_FROM_NAME=CRM Beza, Miranda e Bonetti
SMTP_TLS=true

# ── Claude / Anthropic API ────────────────────────────────────────────────────
# Obtenha em: https://console.anthropic.com
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5
