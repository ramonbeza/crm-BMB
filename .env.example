# Database
POSTGRES_DB=crm_beza
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=supersecret123

# Redis
REDIS_PASSWORD=redissecret123

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=miniosecret123

# JWT — gere com: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Ambiente
ENVIRONMENT=production

# Primeiro admin criado no startup
FIRST_ADMIN_EMAIL=admin@crm.local
FIRST_ADMIN_PASSWORD=Admin@123
FIRST_ADMIN_NAME=Administrador

# ── Google Calendar OAuth2 ────────────────────────────────────────────────────
# Crie credenciais em https://console.cloud.google.com → APIs → Calendar API → Credenciais
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost/api/v1/integrations/google/callback

# ── WhatsApp (Z-API) ──────────────────────────────────────────────────────────
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# ── WhatsApp (Evolution API — alternativa) ────────────────────────────────────
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# ── SMTP (e-mail) ─────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=CRM Beza, Miranda e Bonetti
SMTP_TLS=true
